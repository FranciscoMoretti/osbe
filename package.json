{
  "name": "markdown-clipper",
  "displayName": "Markdown Clipper",
  "version": "0.0.1",
  "description": "Clip whole pages and selections into portable Markdown files.",
  "author": "Fran",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "3.4.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/turndown": "^5.0.5",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "contextMenus",
      "downloads",
      "offscreen",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
