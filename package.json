{
  "name": "osbe",
  "private": true,
  "version": "0.0.0",
  "description": "Open Source Browser Extensions monorepo.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm validate && pnpm test && pnpm typecheck && pnpm build",
    "dev": "pnpm --filter @osbe/markdown-clipper dev",
    "extension": "node scripts/extensions.mjs",
    "test": "node --test scripts/*.test.mjs && pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate": "node scripts/extensions.mjs validate",
    "new:extension": "node scripts/create-extension.mjs"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "prettier": "catalog:",
    "sharp": "catalog:"
  },
  "pnpm": {
    "packageExtensions": {
      "plasmo@0.90.5": {
        "dependencies": {
          "detect-libc": "^2.1.2"
        }
      }
    }
  }
}
