{
  "name": "@osbe/site-blocker",
  "displayName": "OSBE Site Blocker",
  "version": "0.0.3",
  "description": "Block distracting websites and allow temporary access when you need it.",
  "author": "Fran",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@osbe/config": "workspace:*",
    "@osbe/ui": "workspace:*",
    "lucide-react": "catalog:",
    "plasmo": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tldts": "^7.4.8"
  },
  "devDependencies": {
    "@types/chrome": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "postcss": "catalog:",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "alarms",
      "declarativeNetRequest",
      "favicon",
      "storage",
      "webNavigation"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "tabs/blocked.html"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  }
}
